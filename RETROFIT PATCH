<!--
  STEP 6 (audit.html only): Replace the setTimeout submit block in JS with:
-->
<script>
  /* ===== AUDIT FORM: GHL WEBHOOK + NETLIFY DUAL-SUBMIT ===== */
  var GHL_WEBHOOK = 'YOUR_GHL_WEBHOOK_URL_HERE';
  /* To get your GHL webhook URL:
     1. GHL → Automation → Workflows → New Workflow
     2. Set trigger: "Inbound Webhook"
     3. Copy the webhook URL and paste it above */

  var form      = document.getElementById('efAuditForm');
  var submitBtn = document.getElementById('efSubmitBtn');
  var formState = document.getElementById('efFormState');

  form.addEventListener('input', function(e) { e.target.classList.remove('ef-error'); }, true);

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    var req = form.querySelectorAll('[required]'), ok = true, bad = null;
    for (var i = 0; i < req.length; i++) {
      if (!req[i].value.trim()) { req[i].classList.add('ef-error'); ok = false; if (!bad) bad = req[i]; }
    }
    if (!ok) { if (bad) { bad.scrollIntoView({behavior:'smooth',block:'center'}); bad.focus(); } return; }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Submitting...';

    /* Collect form data */
    var data = {
      firstName:    document.getElementById('efFN').value,
      lastName:     document.getElementById('efLN').value,
      email:        document.getElementById('efEmail').value,
      phone:        document.getElementById('efPhone').value,
      businessName: document.getElementById('efBiz').value,
      describe:     document.getElementById('efDescribe').value,
      needMost:     document.getElementById('efNeed').value,
      package:      document.getElementById('efPkg').value,
      bottleneck:   document.getElementById('efBottle').value,
      hasWebsite:   document.getElementById('efWeb').value,
      hasCrm:       document.getElementById('efCRM').value,
      timeline:     document.getElementById('efTime').value,
      budget:       document.getElementById('efBudget').value,
      anythingElse: document.getElementById('efExtra').value
    };

    /* 1. Submit to Netlify Forms (backup capture) */
    var netlifyBody = new URLSearchParams();
    netlifyBody.append('form-name', 'ai-business-audit');
    Object.keys(data).forEach(function(k) { netlifyBody.append(k, data[k]); });
    fetch('/', { method:'POST', headers:{'Content-Type':'application/x-www-form-urlencoded'}, body:netlifyBody.toString() })
      .catch(function() {});

    /* 2. Submit to GHL Webhook (creates contact + triggers workflow) */
    if (GHL_WEBHOOK !== 'YOUR_GHL_WEBHOOK_URL_HERE') {
      fetch(GHL_WEBHOOK, { method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify(data) })
        .catch(function() {});
    }

    /* 3. Redirect to thank-you page */
    setTimeout(function() { window.location.href = 'thank-you.html'; }, 900);
  });
</script>

